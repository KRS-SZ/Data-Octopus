def update_boxplot_tab():
    """Update boxplot visualization with mean and median values"""
    global canvas2, fig2
‚Äã‚Äã‚Äã
    if canvas2:
        canvas2.get_tk_widget().destroy()
    if fig2:
        plt.close(fig2)
‚Äã‚Äã‚Äã
    if not data_arrays:
        return
‚Äã‚Äã‚Äã
    fig2, ax2 = plt.subplots(figsize=(16, 10))
‚Äã‚Äã‚Äã
    bp = ax2.boxplot(
        [arr.flatten() for arr in data_arrays],
        tick_labels=file_names,
        vert=True,
        patch_artist=True,
        showmeans=True,
        meanprops=dict(
            marker="D", markerfacecolor="red", markeredgecolor="red", markersize=8
        ),
        medianprops=dict(color="blue", linewidth=2),
    )
‚Äã‚Äã‚Äã
    for patch in bp["boxes"]:
        patch.set_facecolor("lightblue")
        patch.set_alpha(0.6)
‚Äã‚Äã‚Äã
    for idx, arr in enumerate(data_arrays):
        data = arr.flatten()
        mean_val = np.mean(data)
        median_val = np.median(data)
        x_pos = idx + 1
‚Äã‚Äã‚Äã
        ax2.text(
            x_pos + 0.15,
            mean_val,
            f"Œº={mean_val:.2f}",
            fontsize=9,
            color="red",
            fontweight="bold",
            verticalalignment="center",
        )
        ax2.text(
            x_pos + 0.15,
            median_val,
            f"M={median_val:.2f}",
            fontsize=9,
            color="blue",
            fontweight="bold",
            verticalalignment="center",
        )
‚Äã‚Äã‚Äã
    ax2.set_title(
        "Boxplot of Each Dataset (with Mean and Median)", fontsize=14, fontweight="bold"
    )
    ax2.set_xlabel("Dataset", fontsize=12)
    ax2.set_ylabel("Luminance Value", fontsize=12)
    ax2.grid(True, alpha=0.3, linestyle="--")
‚Äã‚Äã‚Äã
    from matplotlib.lines import Line2D
‚Äã‚Äã‚Äã
    legend_elements = [
        Line2D(
            [0],
            [0],
            marker="D",
            color="w",
            markerfacecolor="red",
            markersize=8,
            label="Mean (Œº)",
        ),
        Line2D([0], [0], color="blue", linewidth=2, label="Median (M)"),
    ]
    ax2.legend(handles=legend_elements, loc="upper right", fontsize=10)
‚Äã‚Äã‚Äã
    fig2.tight_layout()
‚Äã‚Äã‚Äã
    canvas2 = FigureCanvasTkAgg(fig2, master=tab2)
    canvas2.get_tk_widget().pack(fill=tk.BOTH, expand=True)
‚Äã‚Äã‚Äã
