def show_zoomed_image(image_path):
    zoom_win = tk.Toplevel(main_win)
    zoom_win.title(f"Zoomed: {image_path.split('/')[-1]}")
‚Äã‚Äã‚Äã
    zoom_size = [800, 600]
    img = Image.open(image_path)
    img_zoom = img.resize(zoom_size)
    tk_img_zoom = ImageTk.PhotoImage(img_zoom, master=zoom_win)
‚Äã‚Äã‚Äã
    img_label = tk.Label(zoom_win, image=tk_img_zoom)
    img_label.pack()
    img_label.image = tk_img_zoom
‚Äã‚Äã‚Äã
    def zoom_in():
        zoom_size[0] = int(zoom_size[0] * 1.2)
        zoom_size[1] = int(zoom_size[1] * 1.2)
        img_zoom = img.resize(zoom_size)
        tk_img_zoom = ImageTk.PhotoImage(img_zoom, master=zoom_win)
        img_label.config(image=tk_img_zoom)
        img_label.image = tk_img_zoom
‚Äã‚Äã‚Äã
    def zoom_out():
        zoom_size[0] = int(zoom_size[0] / 1.2)
        zoom_size[1] = int(zoom_size[1] / 1.2)
        img_zoom = img.resize(zoom_size)
        tk_img_zoom = ImageTk.PhotoImage(img_zoom, master=zoom_win)
        img_label.config(image=tk_img_zoom)
        img_label.image = tk_img_zoom
‚Äã‚Äã‚Äã
    btn_frame = tk.Frame(zoom_win)
    btn_frame.pack()
    tk.Button(btn_frame, text="Zoom In", command=zoom_in).pack(side=tk.LEFT)
    tk.Button(btn_frame, text="Zoom Out", command=zoom_out).pack(side=tk.LEFT)
‚Äã‚Äã‚Äã
‚Äã‚Äã‚Äã
